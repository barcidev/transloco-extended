{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "e67e3b17-120c-489c-80e2-e28ba0d098ef"
  },
  "newProjectRoot": "projects",
  "projects": {
    "typed-transloco": {
      "projectType": "library",
      "root": "projects/typed-transloco",
      "sourceRoot": "projects/typed-transloco/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/typed-transloco/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/typed-transloco/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/typed-transloco/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
